# ===== ONDRE Oferty — sekrety =====
# Lokalnie: zapisz ten plik jako  .streamlit/secrets.toml  i uzupełnij.
# Na Streamlit Cloud: wklej tę zawartość w  App settings → Secrets.

# --- Trwała baza Postgres (Supabase/Neon). BEZ TEGO dane są ulotne! ---
# Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL = "postgresql://postgres:TWOJE_HASLO@HOST.supabase.com:5432/postgres"

# --- Analiza maili (Claude) ---
ANTHROPIC_API_KEY = "WKLEJ_SWOJ_KLUCZ"   # zalecane: świeżo zrolowany w console.anthropic.com

# --- Pipedrive (opcjonalnie) ---
PIPEDRIVE_API_TOKEN = "WKLEJ_TOKEN"

# --- Automatyczne konto administratora przy pierwszym uruchomieniu (opcjonalne) ---
# Ustaw poniższe, aby po wdrożeniu od razu zalogować się jako admin (bez ekranu konfiguracji).
# Po pierwszym logowaniu możesz je usunąć z sekretów.
BOOTSTRAP_ADMIN_EMAIL = "borys@ondre.pl"
BOOTSTRAP_ADMIN_PASSWORD = "USTAW_MOCNE_HASLO"
BOOTSTRAP_ADMIN_NAME = "Borys"
